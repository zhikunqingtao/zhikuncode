# =============================================================================
# ZhikunCode — Environment Configuration
# Copy this to .env and fill in your values: cp .env.example .env
# =============================================================================

# [REQUIRED] LLM API Key
LLM_API_KEY=your-api-key-here

# [Optional] LLM Provider Base URL (default: Alibaba DashScope)
# ─── Provider Examples ──────────────────────────────────────────────
# Alibaba DashScope (default):
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   LLM_DEFAULT_MODEL=qwen3.6-plus
#   LLM_MODELS=qwen3.6-plus,qwen-max,qwen-plus,qwen-turbo
#
# OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_DEFAULT_MODEL=gpt-4o
#   LLM_MODELS=gpt-4o,gpt-4o-mini,gpt-4-turbo
#
# DeepSeek:
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_DEFAULT_MODEL=deepseek-chat
#   LLM_MODELS=deepseek-chat,deepseek-reasoner
#
# Moonshot (Kimi):
#   LLM_BASE_URL=https://api.moonshot.cn/v1
#   LLM_DEFAULT_MODEL=moonshot-v1-auto
#   LLM_MODELS=moonshot-v1-auto,moonshot-v1-32k,moonshot-v1-128k
#
# Local Ollama:
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_DEFAULT_MODEL=qwen2.5:latest
#   LLM_MODELS=qwen2.5:latest,codellama:latest
# ───────────────────────────────────────────────────────────────
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_DEFAULT_MODEL=qwen3.6-plus
# LLM_MODELS=qwen3.6-plus,qwen-max,qwen-plus,qwen-turbo,qwen-coder-plus

# [Optional] Host port mapping (default: 8080)
# ZHIKUN_PORT=8080

# [Optional] Spring profile (default: production)
# SPRING_PROFILES_ACTIVE=production

# [Optional] JVM options
# JAVA_OPTS=-Xms256m -Xmx1024m --enable-preview

# [Optional] Workspace path to mount into container
# WORKSPACE_PATH=./workspace

# Feature flags
ZHIKUN_COORDINATOR_MODE=0

# =============================================================================
# Docker Advanced Configuration (usually no change needed)
# =============================================================================

# [Optional] Allow private network access without auth token (Docker default: true)
# When running in Docker, requests from Docker bridge network bypass authentication.
# Set to 'false' to require auth token for all non-localhost requests.
# ALLOW_PRIVATE_NETWORK=true

# [Optional] Container log directory (Docker default: /app/log)
# LOG_DIR=/app/log

# [Optional] MCP capability registry file path
# MCP_REGISTRY_PATH=/app/configuration/mcp/mcp_capability_registry.json
